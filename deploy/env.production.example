# Production .env — copy to project root as .env on the server
# cp deploy/env.production.example .env && nano .env

# ── Gemini / Vertex AI ────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# EC2 only (set when using docker-compose.ec2.yml):
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa-key.json

# ── OpenRouter (embeddings → Pinecone) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

# ── SerpAPI (identity rescue + image + HK retailer search) ────────────────
SERPAPI_API_KEY=...
SERPAPI_AI_MODE_MAX_CALLS=2
SERPAPI_AI_MODE_CACHE_TTL=86400
SERPAPI_AI_MODE_LOCATION=Hong Kong
SERPAPI_IDENTITY_SEARCH_MAX_CALLS=2
SERPAPI_IDENTITY_SEARCH_CACHE_TTL=86400
SERPAPI_IMAGE_MAX_CALLS=1
SERPAPI_HK_MAX_CALLS=3
SERPAPI_TOTAL_MAX_CALLS=7

# ── Redis ───────────────────────────────────────────────────────────────────
# Docker:  redis://redis:6379/0
# Native:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# ── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=pet-food-products
PINECONE_DIMENSION=1536
PINECONE_NAMESPACE=pet-food

# ── Local HK retailer catalog (scraped CSV import) ───────────────────────────
HK_CATALOG_ENABLED=1
HK_CATALOG_DB_PATH=data/hk_retailer_catalog.db
# Portable defaults — paths relative to project root (same on Mac, Linux, VM):
HK_CATALOG_IMPORT_HKTVMALL_DIR=data/imports/hktvmall
HK_CATALOG_IMPORT_SHOPIFY_DIR=data/imports/shopify
HK_CATALOG_IMPORT_MASTER_SCRAPE_DIR=data/imports/master_scrape
# Optional: override with absolute paths on a specific machine, e.g.
# HK_CATALOG_IMPORT_HKTVMALL_DIR=/srv/scrapes/hktvmall_worksheets_csv_files

# ── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Dashboard metrics — persisted across API restarts (JSONL on disk)
METRICS_ENABLED=true
METRICS_STORE_PATH=data/lookup_metrics.jsonl
METRICS_RETENTION_DAYS=30

# Optional: require ?token=... on /api/stats (leave empty for open dashboard)
# STATS_TOKEN=your-secret-token

# Public port exposed on the VM (80 = http://YOUR_IP/)
APP_PORT=80
