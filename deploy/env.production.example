# Production .env — copy to project root as .env on the server
# cp deploy/env.production.example .env && nano .env

# ── Gemini / Vertex AI ────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# EC2 only (set when using docker-compose.ec2.yml):
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa-key.json

# ── OpenRouter (embeddings → Pinecone) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

# ── SerpAPI (image + HK retailer search) ────────────────────────────────────
SERPAPI_API_KEY=...
SERPAPI_IMAGE_MAX_CALLS=1
SERPAPI_HK_MAX_CALLS=3
SERPAPI_TOTAL_MAX_CALLS=4

# ── Redis ───────────────────────────────────────────────────────────────────
# Docker:  redis://redis:6379/0
# Native:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# ── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=pet-food-products
PINECONE_DIMENSION=1536
PINECONE_NAMESPACE=pet-food

# ── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Public port exposed on the VM (80 = http://YOUR_IP/)
APP_PORT=80
