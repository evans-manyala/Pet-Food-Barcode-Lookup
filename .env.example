# ─────────────────────────────────────────────────────────────────────────────
# Pet Food Barcode Lookup – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Direct key enables Google Search Grounding (live web search)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-3.5-flash

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Used ONLY for generating text embeddings (OpenAI text-embedding-3-small)
# sent to Pinecone.  Add OpenAI under your OpenRouter keys.
# Sign up at: https://openrouter.ai/
OPENROUTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

#── SERP API  ─────────────────────────────────────────────────────────────────────
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

SERPAPI_IMAGE_MAX_CALLS=1
SERPAPI_HK_MAX_CALLS=3
SERPAPI_TOTAL_MAX_CALLS=4

SERPAPI_IMAGE_MAX_CANDIDATES=20
SERPAPI_HK_MAX_CANDIDATES=15
SERPAPI_VISION_MAX_CANDIDATES=1

SERPAPI_CACHE_ENABLED=1
SERPAPI_IMAGE_CACHE_TTL=604800
SERPAPI_HK_CACHE_TTL=86400

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379/0
# Cloud:  redis://:<password>@<host>:<port>/0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400     # seconds — default 24 hours

# ── Pinecone ──────────────────────────────────────────────────────────────────
# Sign up at: https://www.pinecone.io/
PINECONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_HOST=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_DIMENSION=1536   # must match text-embedding-3-small output dims

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


GOOGLE_CLOUD_PROJECT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLOUD_LOCATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   