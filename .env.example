# ─────────────────────────────────────────────────────────────────────────────
# Pet Food Barcode Lookup – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Direct key enables Google Search Grounding (live web search)
# Get yours at: https://aistudio.google.com/app/apikey
#GEMINI_API_KEY=AQ.Ab8RN6I2YQ2uphd_g4F3PKnOTjWFTcg1TZmiNgvlKbU3s-ontg
#GEMINI_API_KEY=AQ.Ab8RN6LyLWjc5XpwpYWbgFXDt9__MPp8fYP7Dvq7uTyEN55e5g
GEMINI_MODEL=gemini-3.5-flash

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Used ONLY for generating text embeddings (OpenAI text-embedding-3-small)
# sent to Pinecone.  Add OpenAI under your OpenRouter keys.
# Sign up at: https://openrouter.ai/
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

#── SERP API  ─────────────────────────────────────────────────────────────────────
SERPAPI_API_KEY=848e65f9020045ffd31206783b503f293809cda50558d295fd91d16b542e0331
SERPAPI_IMAGE_MAX_CALLS=1
SERPAPI_HK_MAX_CALLS=3
SERPAPI_TOTAL_MAX_CALLS=4

SERPAPI_IMAGE_MAX_CANDIDATES=20
SERPAPI_HK_MAX_CANDIDATES=15
SERPAPI_VISION_MAX_CANDIDATES=1

SERPAPI_CACHE_ENABLED=1
SERPAPI_IMAGE_CACHE_TTL=604800
SERPAPI_HK_CACHE_TTL=86400

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379/0
# Cloud:  redis://:<password>@<host>:<port>/0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400     # seconds — default 24 hours

# ── Pinecone ──────────────────────────────────────────────────────────────────
# Sign up at: https://www.pinecone.io/
PINECONE_API_KEY=pcsk_3iVRa8_Pj46q5h8xEMo8ZnjCg8T2Cpm3Kwik5mCBrRVX7KJfERTHqjUxmAKT4LwxXRjzit
PINECONE_HOST=pet-food-products-3kmva7f.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX_NAME=pet-food-products
PINECONE_DIMENSION=1536   # must match text-embedding-3-small output dims

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


GOOGLE_CLOUD_PROJECT=project-11d80abc-a7c0-43df-9ed
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-pro